{
  "appId": "com.ggmp.marketplace",
  "appName": "GGMP",
  "webDir": "public",
  "server": {
    "url": "https://gemmarket.vercel.app",
    "cleartext": true,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "backgroundColor": "#ffffff",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true,
      "androidScaleType": "CENTER_CROP"
    }
  }
}