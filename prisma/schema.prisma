generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  phone      String?
  whatsapp   String?
  telegram   String?
  line       String?
  role       Role      @default(USER)
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())
  listings   Listing[]
  otps       Otp[]
}

model Listing {
  id                 String        @id @default(cuid())
  title              String
  price              Float
  gemType            String
  carat              Float
  color              String
  clarity            String?
  cut                String?
  origin             String?
  description        String        @db.Text
  whatsappNumber     String
  telegram           String?
  line               String?
  location           String?
  isCertified        Boolean       @default(false)
  availability       String        @default("Available")
  certificationImage String?
  status             ListingStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images             Image[]
  videos             Video[]       
  tracking           Tracking?
}

model Image {
  id        String  @id @default(cuid())
  listingId String
  imageUrl  String
  publicId  String?
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Video {
  id        String  @id @default(cuid())
  listingId String
  videoUrl  String
  publicId  String?
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Tracking {
  id             String  @id @default(cuid())
  listingId      String  @unique
  whatsappClicks Int     @default(0)
  listing        Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
